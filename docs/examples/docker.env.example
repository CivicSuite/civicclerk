# Copy to .env before using docker compose if you want to override defaults.
# Do not commit a real .env file.

CIVICCLERK_POSTGRES_USER=civicclerk
CIVICCLERK_POSTGRES_PASSWORD=change-this-before-shared-use
CIVICCLERK_POSTGRES_DB=civicclerk

# Ports exposed on the host workstation.
CIVICCLERK_API_PORT=8776
CIVICCLERK_WEB_PORT=8080

# Local/demo mode only. Use oidc, bearer, or trusted_header before shared deployment.
CIVICCLERK_STAFF_AUTH_MODE=open

# Seed Brookfield demo meetings, agenda intake, packets, notices, outcomes,
# minutes, and public archive data when the API process starts.
# Set to 0 for an empty local rehearsal database.
CIVICCLERK_DEMO_SEED=1

# Optional local-first scheduled connector import sync. Leave disabled until IT
# has an approved local export drop folder from Granicus, Legistar, PrimeGov, or
# NovusAGENDA. This does not contact vendor networks.
CIVICCLERK_CONNECTOR_SYNC_ENABLED=false
CIVICCLERK_CONNECTOR_SYNC_PAYLOAD_DIR_HOST=./connector-imports
CIVICCLERK_CONNECTOR_SYNC_LEDGER_PATH=/data/exports/connector-import-ledger.json
CIVICCLERK_CONNECTOR_SYNC_CONNECTORS=
CIVICCLERK_CONNECTOR_SYNC_INTERVAL_SECONDS=900

# Optional scheduled vendor-network sync. Leave both gates disabled until IT has
# approved source records, verified credentials, and accepted live vendor pulls.
# Source IDs are created through /vendor-live-sync/sources. Prefer a shared
# secret env for one-source pilots, or add per-source secret env vars to
# docker-compose.yml using the configured prefix before enabling multiple
# sources.
CIVICCLERK_VENDOR_NETWORK_SYNC_ENABLED=false
CIVICCLERK_VENDOR_NETWORK_SYNC_SCHEDULE_ENABLED=false
CIVICCLERK_VENDOR_NETWORK_SYNC_SOURCE_IDS=
CIVICCLERK_VENDOR_NETWORK_SYNC_AUTH_SECRET_ENV=CIVICCLERK_VENDOR_NETWORK_SYNC_SHARED_SECRET
CIVICCLERK_VENDOR_NETWORK_SYNC_AUTH_SECRET_ENV_PREFIX=CIVICCLERK_VENDOR_SECRET_
CIVICCLERK_VENDOR_NETWORK_SYNC_SHARED_SECRET=
CIVICCLERK_VENDOR_NETWORK_SYNC_REPORT_DIR=/data/exports/vendor-network-sync
CIVICCLERK_VENDOR_NETWORK_SYNC_INTERVAL_SECONDS=900

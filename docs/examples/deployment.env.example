# CivicClerk deployment profile example.
#
# Copy this file to a deployment-specific path, replace every placeholder, keep
# the completed file out of source control, then validate it with:
#
#   python scripts/check_deployment_readiness.py --env-file path/to/deployment.env --strict
#
# OIDC mode is the preferred protected deployment profile for municipal SSO.
# Replace the placeholders with the city's identity-provider values. For
# trusted-header deployment instead, set CIVICCLERK_STAFF_AUTH_MODE=trusted_header
# and use docs/examples/trusted-header-nginx.conf.

CIVICCLERK_STAFF_AUTH_MODE=oidc
CIVICCLERK_STAFF_OIDC_PROVIDER=City Entra ID
CIVICCLERK_STAFF_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
CIVICCLERK_STAFF_OIDC_AUDIENCE=api://civicclerk
CIVICCLERK_STAFF_OIDC_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
CIVICCLERK_STAFF_OIDC_ROLE_CLAIMS=roles,groups
CIVICCLERK_STAFF_OIDC_ALGORITHMS=RS256
CIVICCLERK_STAFF_OIDC_AUTHORIZATION_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
CIVICCLERK_STAFF_OIDC_TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
CIVICCLERK_STAFF_OIDC_CLIENT_ID=<application-client-id>
CIVICCLERK_STAFF_OIDC_CLIENT_SECRET=<application-client-secret>
CIVICCLERK_STAFF_OIDC_REDIRECT_URI=https://civicclerk.example.gov/staff/oidc/callback
CIVICCLERK_STAFF_OIDC_SESSION_COOKIE_SECRET=<strong-random-session-cookie-secret>

# Bearer mode remains available for constrained pilots before OIDC is wired:
# CIVICCLERK_STAFF_AUTH_MODE=bearer
# CIVICCLERK_STAFF_AUTH_TOKEN_ROLES='{"replace-with-secret-token":["clerk_admin","meeting_editor"]}'

CIVICCLERK_AGENDA_INTAKE_DB_URL=sqlite+pysqlite:///C:/civicclerk-data/agenda-intake.db
CIVICCLERK_AGENDA_ITEM_DB_URL=sqlite+pysqlite:///C:/civicclerk-data/agenda-items.db
CIVICCLERK_MEETING_DB_URL=sqlite+pysqlite:///C:/civicclerk-data/meetings.db
CIVICCLERK_PACKET_ASSEMBLY_DB_URL=sqlite+pysqlite:///C:/civicclerk-data/packet-assembly.db
CIVICCLERK_NOTICE_CHECKLIST_DB_URL=sqlite+pysqlite:///C:/civicclerk-data/notice-checklist.db
CIVICCLERK_VENDOR_SYNC_DB_URL=sqlite+pysqlite:///C:/civicclerk-data/vendor-sync.db

CIVICCLERK_EXPORT_ROOT=C:/civicclerk-exports
CIVICCLERK_DEPLOYMENT_PREFLIGHT_DIST_ROOT=dist

# Keep scheduled vendor-network sync disabled until IT has created approved
# /vendor-live-sync/sources records, verified vendor credentials, and accepted
# live pulls from the municipal network.
CIVICCLERK_VENDOR_NETWORK_SYNC_ENABLED=false
CIVICCLERK_VENDOR_NETWORK_SYNC_SCHEDULE_ENABLED=false
CIVICCLERK_VENDOR_NETWORK_SYNC_SOURCE_IDS=
CIVICCLERK_VENDOR_NETWORK_SYNC_AUTH_SECRET_ENV=CIVICCLERK_VENDOR_NETWORK_SYNC_SHARED_SECRET
CIVICCLERK_VENDOR_NETWORK_SYNC_AUTH_SECRET_ENV_PREFIX=CIVICCLERK_VENDOR_SECRET_
CIVICCLERK_VENDOR_NETWORK_SYNC_SHARED_SECRET=<vendor-api-secret-if-enabled>
CIVICCLERK_VENDOR_NETWORK_SYNC_REPORT_DIR=C:/civicclerk-exports/vendor-network-sync
CIVICCLERK_VENDOR_NETWORK_SYNC_INTERVAL_SECONDS=900
